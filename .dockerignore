# Keep the Docker build context lean; mirror .gitignore plus a few extras
node_modules
**/node_modules

# Docusaurus build output and cache
sites/*/build
sites/*/.docusaurus
sites/*/.cache-loader

# Git + editor metadata
.git
.gitignore
.github
.vscode
.idea

# OS / log
.DS_Store
*.log

# The static brand book is served by GitHub Pages directly,
# not built by Docusaurus. Skip it from the docker context to
# keep image builds fast.
preview
brand
screenshots
.playwright-mcp
.claude
uploads
briefs

# Dockerfiles themselves don't need to ship inside the image
**/Dockerfile
docker-compose.yml
